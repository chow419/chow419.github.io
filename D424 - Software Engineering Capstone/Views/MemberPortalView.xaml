<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="D424___Software_Engineering_Capstone.Views.MemberPortalView"
             xmlns:views="clr-namespace:D424___Software_Engineering_Capstone.Views"
             xmlns:model="clr-namespace:D424___Software_Engineering_Capstone.Models">

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="ProfileMenuIcon"
             IconImageSource="profile_menu_icon.png"
             Clicked="OnProfileMenuButtonTapped"
             IsEnabled="False"/>
    </ContentPage.ToolbarItems>

    <Grid>

        <Grid RowDefinitions="Auto,*"
              Padding="50"
              RowSpacing="50">

            <HorizontalStackLayout x:Name="Title"
                                   HorizontalOptions="Center"
                                   Grid.Row="0">
                <Label Text="Hello, "
                       FontFamily="Lora-Italic"
                       FontSize="24"
                       Style="{StaticResource Headline} "/>
                <Label Text="{Binding FirstName}"
                       Style="{StaticResource Headline} "/>
            </HorizontalStackLayout>

            <Grid Grid.Row="1"
                  RowDefinitions="Auto,Auto,Auto,*,Auto"
                  ColumnDefinitions="*,*">

                <DatePicker x:Name="ScoreDatePicker"
                            Grid.Row="0"
                            Grid.Column="0" />
                <Entry x:Name="ScoreEntry"
                       Grid.Row="0"
                       Grid.Column="1"
                       Placeholder="ex: 72" />

                <Button x:Name="ScoreSubmitButton"
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Text="Submit"
                        HorizontalOptions="Center"
                        Clicked="OnScoreSubmitButtonClicked" />

                <Grid Grid.Row="2"
                      RowDefinitions="Auto,Auto">

                    <Label Grid.Row="0"
                           HorizontalOptions="Center"
                           Text="Course Average"
                           FontFamily="Lora-Italic" />
                    <Label Grid.Row="1"
                           HorizontalOptions="Center"
                           Text="{Binding ScoreAverage}"
                           FontFamily="Lora-Italic" />

                </Grid>

                <VerticalStackLayout Grid.Row="3"
                                     BindableLayout.ItemsSource="{Binding ScoreList}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="model:ScoreModel">

                            <Grid ColumnDefinitions="*,Auto">

                                <Border Grid.Column="0">
                                    <Label Text="{Binding Date}" />
                                </Border>
                                <Border Grid.Column="1">
                                    <Label Text="{Binding Score}" />
                                </Border>

                            </Grid>

                        </DataTemplate>
                    </BindableLayout.ItemTemplate>

                </VerticalStackLayout>

                <Button x:Name="EditContactInfoButton"
                        Grid.Row="4"
                        Text="Edit Contact Info"
                        HorizontalOptions="Center"
                        Clicked="OnEditContactInfoButtonClicked" />

            </Grid>

        </Grid>

        <views:ProfileOptionsOverlayView x:Name="_profileOptionsOverlay" IsVisible="False" />
        <views:SignInOverlayView x:Name="_signInOverlay" IsVisible="False" />
        <views:SignUpOverlayView x:Name="_signUpOverlay" IsVisible="False" />
        <views:AdminPortalOverlayView x:Name="_adminPortalOverlay" IsVisible="False" />

    </Grid>

</ContentPage>