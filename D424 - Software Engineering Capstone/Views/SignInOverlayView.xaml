<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="D424___Software_Engineering_Capstone.Views.SignInOverlayView">

    <Grid x:Name="MainOverlay"
      Grid.ColumnSpan="2"
      Grid.RowSpan="3"
      BackgroundColor="DarkGreen"
      Opacity="0.96">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer />
        </Grid.GestureRecognizers>

        <!-- Sign In Overlay -->
        <Border x:Name="SignInBorder"
            HorizontalOptions="Center"
            VerticalOptions="Center">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>

            <Grid x:Name="SignInOverlay"
              ColumnDefinitions="*,Auto"
              RowDefinitions="Auto,Auto,Auto,Auto"
              ColumnSpacing="50"
              RowSpacing="20"
              BackgroundColor="White"
              Padding="15">

                <!-- Sign In Title -->
                <Label Grid.Column="0"
                   Grid.Row="0"
                   Grid.ColumnSpan="2"
                   Text="Sign In"
                   Style="{StaticResource Headline}"/>

                <!-- Sign In Entry Fields -->
                <VerticalStackLayout Grid.Column="0"
                                 Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Spacing="15">

                    <!-- Sign In Username Entry -->
                    <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="25">
                        <Label Grid.Column="0"
                           Text="Username"
                           VerticalTextAlignment="Center" />
                        <Border Grid.Column="1">
                            <Entry x:Name="SignInUsernameEntry"
                               VerticalOptions="Center"
                               HorizontalOptions="Fill"/>
                        </Border>
                    </Grid>

                    <!-- Sign In Password Entry -->
                    <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="25">
                        <Label Grid.Column="0"
                           Text="Password"
                           VerticalTextAlignment="Center" />
                        <Border Grid.Column="1">
                            <Entry x:Name="SignInPasswordEntry"
                               VerticalOptions="Center"
                               HorizontalOptions="Fill"
                               IsPassword="True" />
                        </Border>
                    </Grid>

                </VerticalStackLayout>

                <!-- Sign Up -->
                <HorizontalStackLayout Grid.Column="0"
                                   Grid.Row="2"
                                   Spacing="15">
                    <Label Text="Don't have an account?"
                       VerticalTextAlignment="Center" />
                    <Label x:Name="SignUpLabel"
                       Text="Sign Up"
                       Style="{StaticResource Link}"
                       VerticalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSignUpLabelTapped"
                                              NumberOfTapsRequired="1" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- Continue as Guest -->
                <Label x:Name="ContinueAsGuestLabel"
                   Grid.Column="0"
                   Grid.Row="3"
                   Text="Continue As Guest"
                   Style="{StaticResource Link}"
                   HorizontalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnContinueAsGuestLabelTapped"
                                          NumberOfTapsRequired="1" />
                    </Label.GestureRecognizers>
                </Label>

                <!-- Sign In Button -->
                <Button x:Name="SignInButton"
                    Grid.Column="1"
                    Grid.Row="2"
                    Grid.RowSpan="2"
                    VerticalOptions="Center"
                    Text="Sign In"
                    Clicked="OnSignInButtonClicked"
                    Style="{StaticResource OverlayButton}"/>

            </Grid>

        </Border>

    </Grid>

</ContentView>
