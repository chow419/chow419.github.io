<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="D424___Software_Engineering_Capstone.Views.AdminPortalOverlayView"
             xmlns:model="clr-namespace:D424___Software_Engineering_Capstone.Models"
             xmlns:converters="clr-namespace:D424___Software_Engineering_Capstone.Converters">

    <ContentView.Resources>
        <converters:BoolToYesNoConverter x:Key="BoolToYesNoConverter" />
        <converters:PhoneNumberFormatterConverter x:Key="PhoneNumberFormatterConverter" />
    </ContentView.Resources>

    <Grid x:Name="MainOverlay"
          BackgroundColor="DarkGreen"
          Opacity="0.96">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer />
            </Grid.GestureRecognizers>

        <!-- View Reservations Overlay -->
        <Border x:Name="ViewReservationsBorder"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                IsVisible="False">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>

            <Grid x:Name="ViewReservationsOverlay"
                  RowDefinitions="Auto,Auto,*,Auto"
                  RowSpacing="20"
                  BackgroundColor="White"
                  Padding="10"
                  MinimumWidthRequest="325">

                <Label Grid.Row="0"
                       Grid.Column="0"
                       Text="Reservations"
                       Style="{StaticResource Headline}" />

                <Grid Grid.Row="1"
                      Grid.Column="0"
                      RowDefinitions="Auto,Auto"
                      ColumnDefinitions="Auto,Auto,*">

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Text="Filter By Date: "
                           VerticalTextAlignment="Center"/>
                    <Switch x:Name="FilterByDateSwith"
                            Grid.Row="0"
                            Grid.Column="1"
                            IsToggled="{Binding IsFilterByDateEnabled}"
                            Toggled="OnFilterByDateSwitchToggled"/>
                    <DatePicker x:Name="ReservationDatePicker"
                                Grid.Row="0"
                                Grid.Column="2"
                                IsVisible="{Binding IsFilterByDateEnabled}"
                                HorizontalOptions="End"
                                DateSelected="OnReservationDateChanged"/>

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Text="Filter By Player: "
                           VerticalTextAlignment="Center" />
                    <Switch x:Name="FilterByPlayerSwitch"
                            Grid.Row="1"
                            Grid.Column="1"
                            IsToggled="{Binding IsFilterByPlayerEnabled}"
                            Toggled="OnFilterByNameSwitchToggled"/>
                    <Entry x:Name="ReservationNameEntry"
                           Grid.Row="1"
                           Grid.Column="2"
                           Placeholder="Player Name"
                           IsVisible="{Binding IsFilterByPlayerEnabled}"
                           TextChanged="OnPlayerNameChanged" />

                </Grid>
                
                <ScrollView Grid.Row="2"
                            VerticalOptions="Start">
                    <VerticalStackLayout>
                        <!-- Title Bar / Column Headers -->
                        <Grid ColumnDefinitions="90,75,*,45,25" Padding="5" BackgroundColor="#e0e0e0">
                            <Label Grid.Column="0" Text="Date" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="1" Text="Time" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="2" Text="Player Name" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="3" Text="Guest" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="4" Text="#" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                        </Grid>
                        <!-- Reservation List -->
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding FilteredReservations}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="model:ReservationModel">
                                    <Grid ColumnDefinitions="90,75,*,45,25">
                                        <Border Grid.Column="0" Padding="5">
                                            <Label Text="{Binding Date, StringFormat='{0:MM/dd/yyyy}'}" />
                                        </Border>
                                        <Border Grid.Column="1" Padding="5">
                                            <Label Text="{Binding Time, StringFormat='{0:h:mm tt}'}" />
                                        </Border>
                                        <Border Grid.Column="2" Padding="5">
                                            <Label Text="{Binding Player.FullName}" HorizontalTextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="3" Padding="5">
                                            <Label Text="{Binding IsPlayerGuest, Converter={StaticResource BoolToYesNoConverter}}" />
                                        </Border>
                                        <Border Grid.Column="4" Padding="5">
                                            <Label Text="{Binding NumberOfPlayers}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>
                
                <Button Grid.Row="3"
                        Grid.Column="0"
                        Text="Close"
                        Style="{StaticResource OverlayButton}"
                        HorizontalOptions="Center"
                        Clicked="OnViewReservationsClosedClicked"/>

            </Grid>

        </Border>

        <!-- View Signed Up Users Overlay -->
        <Border x:Name="ViewSignedUpUsersBorder"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                IsVisible="False">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>

            <Grid x:Name="ViewUsersOverlay"
                      RowDefinitions="Auto,Auto,*,Auto"
                      RowSpacing="20"
                      BackgroundColor="White"
                      Padding="10"
                      MinimumWidthRequest="325">

                    <!-- Title -->
                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Text="Signed-Up Users"
                           Style="{StaticResource Headline}" />

                    <!-- Filter Information -->
                    <Grid Grid.Row="1"
                          Grid.Column="0"
                          ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0"
                               Text="Filter By Name: "
                               VerticalTextAlignment="Center" />
                        <Entry x:Name="NameFilterEntry"
                               Grid.Column="2"
                               Placeholder="User Name"
                               TextChanged="OnNameFilterTextChanged" />
                    </Grid>
                    

                <ScrollView Grid.Row="2"
                            VerticalOptions="Start">
                    <VerticalStackLayout>
                        <!-- Title Bar / Column Headers -->
                        <Grid ColumnDefinitions="*,65" Padding="5" BackgroundColor="#e0e0e0">
                            <Label Grid.Column="0" Text="Player Name" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="1" Text="Admin" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                        </Grid>
                        <!-- Reservation List -->
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding FilteredUsers}">
                            <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="model:UserModel">
                                    <Grid ColumnDefinitions="*,65">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer x:Name="UserEntryTap"
                                                                  Tapped="UserEntryTapped"
                                                                  CommandParameter="{Binding .}"/>
                                        </Grid.GestureRecognizers>
                                        <Border Grid.Column="0" Padding="5">
                                            <Label Text="{Binding FullName}" HorizontalTextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="1" Padding="5">
                                            <Label Text="{Binding IsAdmin, Converter={StaticResource BoolToYesNoConverter}}"
                                                   HorizontalTextAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <Button Grid.Row="3"
                            Grid.Column="0"
                            Text="Close"
                            Style="{StaticResource OverlayButton}"
                            HorizontalOptions="Center"
                            Clicked="OnViewUsersCloseButtonClicked"/>
            </Grid>

        </Border>

        <!-- View Guests Overlay -->
        <Border x:Name="ViewGuestsBorder"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                IsVisible="False">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>

            <Grid x:Name="ViewGuestsOverlay"
                  RowDefinitions="Auto,Auto,*,Auto"
                  RowSpacing="20"
                  BackgroundColor="White"
                  Padding="10"
                  MinimumWidthRequest="325">

                <!-- Title -->
                <Label Grid.Row="0"
                       Grid.Column="0"
                       Text="Guests"
                       Style="{StaticResource Headline}" />

                <!-- Filter Information -->
                <Grid Grid.Row="1"
                      Grid.Column="0"
                      ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0"
                           Text="Filter By Name: "
                           VerticalTextAlignment="Center" />
                    <Entry x:Name="GuestNameFilterEntry"
                           Grid.Column="2"
                           Placeholder="User Name"
                           TextChanged="OnNameFilterTextChanged" />
                </Grid>


                <ScrollView Grid.Row="2"
                            VerticalOptions="Start">
                    <VerticalStackLayout>
                        <!-- Title Bar / Column Headers -->
                        <Grid ColumnDefinitions="*,110" Padding="5" BackgroundColor="#e0e0e0">
                            <Label Grid.Column="0" Text="Player Name" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="1" Text="Phone #" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                        </Grid>
                        <!-- Reservation List -->
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding FilteredUsers}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="model:GuestModel">
                                    <Grid ColumnDefinitions="*,110">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer x:Name="UserEntryTap"
                                                                  Tapped="UserEntryTapped"
                                                                  CommandParameter="{Binding .}"/>
                                        </Grid.GestureRecognizers>
                                        <Border Grid.Column="0" Padding="5">
                                            <Label Text="{Binding FullName}" HorizontalTextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="1" Padding="5">
                                            <Label Text="{Binding PhoneNumber, Converter={StaticResource PhoneNumberFormatterConverter}}"
                                                   HorizontalTextAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <Button Grid.Row="3"
                        Grid.Column="0"
                        Text="Close"
                        Style="{StaticResource OverlayButton}"
                        HorizontalOptions="Center"
                        Clicked="OnViewGuestsCloseButtonClicked"/>
            </Grid>

        </Border>

        <!-- View Course News Overlay -->
        <Border x:Name="ViewCourseNewsBorder"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                IsVisible="False">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>

            <Grid x:Name="ViewCourseNewsOverlay"
                  ColumnDefinitions="Auto,Auto,Auto,*"
                  RowDefinitions="Auto,Auto,*,Auto,Auto"
                  ColumnSpacing="10"
                  RowSpacing="20"
                  BackgroundColor="White"
                  Padding="10"
                  WidthRequest="325">

                <Label Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="4"/>

                <Grid Grid.Row="1"
                      Grid.Column="0"
                      Grid.ColumnSpan="4"
                      ColumnDefinitions="Auto,*">

                    <Label Grid.Column="0"
                           Text="Title" />
                    <Entry x:Name="CourseNewsTitleEntry"
                           Grid.Column="1" />

                </Grid>

                <Grid Grid.Row="2"
                      Grid.Column="0"
                      Grid.ColumnSpan="4"
                      ColumnDefinitions="Auto,*">

                    <Label Grid.Column="0"
                           Text="Details" />
                    <Editor x:Name="CourseNewsDetailsEditor"
                            Grid.Column="1"
                            HeightRequest="250"/>

                </Grid>

                <Label Grid.Row="3"
                       Grid.Column="0"
                       VerticalTextAlignment="Center"
                       Text="Closed?" />
                <Switch x:Name="IsClosedSwitch"
                        Grid.Row="3"
                        Grid.Column="1"
                        IsToggled="{Binding IsCourseClosedSwitchEnabled}"/>
                <DatePicker x:Name="CourseClosedDate"
                            Grid.Row="3"
                            Grid.Column="2"
                            IsEnabled="{Binding IsCourseClosedSwitchEnabled}" />
                <Picker x:Name="CourseClosedReasonPicker"
                        Grid.Row="3"
                        Grid.Column="3"
                        IsEnabled="{Binding IsCourseClosedSwitchEnabled}"
                        Title="Reason">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Weather</x:String>
                            <x:String>Maintenance</x:String>
                            <x:String>Tournament</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>

                <Grid Grid.Row="4"
                      Grid.Column="0"
                      Grid.ColumnSpan="4"
                      ColumnDefinitions="*,*">

                    <Button x:Name="CourseNewsCancelButton"
                            Grid.Column="0"
                            Text="Cancel"
                            Clicked="OnCourseNewsCancelButtonClicked"
                            HorizontalOptions="Center"
                            Style="{StaticResource OverlayButton}"/>
                    <Button x:Name="CourseNewsSubmitButton"
                            Grid.Column="1"
                            Text="Submit"
                            Clicked="OnCourseNewsSubmitButtonClicked"
                            HorizontalOptions="Center"
                            Style="{StaticResource OverlayButton}"/>

                </Grid>

            </Grid>

        </Border>

        <!-- View Contact Us Info Overlay -->
        <Border x:Name="ViewContactUsInfoBorder"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                IsVisible="False">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>

            <Grid x:Name="ViewContactUsInfoOverlay"
                  ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto"
                  IsVisible="False"
                  ColumnSpacing="50"
                  RowSpacing="20"
                  BackgroundColor="White"
                  Padding="10"
                  WidthRequest="325">

            </Grid>

        </Border>
        
        <!-- Selected User Overlay -->
        <Border>
            <Border x:Name="SelectedOverlay"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    IsVisible="False">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <Grid x:Name="SelectedUserGrid"
                      RowDefinitions="Auto,*,Auto"
                      ColumnSpacing="50"
                      RowSpacing="20"
                      BackgroundColor="White"
                      Padding="10"
                      WidthRequest="325">

                    <!-- Title -->
                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding FullName}"
                           Style="{StaticResource Headline}" />
                    
                    <VerticalStackLayout Grid.Row="1"
                                         HorizontalOptions="Center">
                        <Label Text="Phone Number"
                               Style="{StaticResource SubHeadline}"
                               Margin="0,20,0,5"/>
                        <Label x:Name="PhoneNumberLabel"
                               Text="{Binding PhoneNumber, Converter={StaticResource PhoneNumberFormatterConverter}}"
                               IsVisible="True"
                               HorizontalTextAlignment="Center"
                               FontSize="18"/>
                        <Label Text="Email Address"
                               Style="{StaticResource SubHeadline}"
                               Margin="0,20,0,5"/>
                        <Label x:Name="EmailLabel"
                               Text="{Binding Email}"
                               IsVisible="True"
                               HorizontalTextAlignment="Center"
                               FontSize="18"/>
                        <Label Text="Date of Birth"
                               Style="{StaticResource SubHeadline}"
                               Margin="0,20,0,5"/>
                        <Label x:Name="DateOfBirthLabel"
                               Text="{Binding DateOfBirth, StringFormat='{0:MM/dd/yyyy}'}"
                               IsVisible="True"
                               HorizontalTextAlignment="Center"
                               FontSize="18"/>
                        <Label Text="Address"
                               Style="{StaticResource SubHeadline}"
                               Margin="0,20,0,5"/>
                        <Label x:Name="Address1Label"
                               Text="{Binding StreetAddress}"
                               IsVisible="True"
                               HorizontalTextAlignment="Center"
                               FontSize="18"/>
                        <Label x:Name="Address2Label"
                               Text="{Binding AddressLine2}"
                               IsVisible="True"
                               HorizontalTextAlignment="Center"
                               FontSize="18"/>
                        <HorizontalStackLayout x:Name="CityStateLabels"
                                               IsVisible="True"
                                               HorizontalOptions="Center">
                            <Label Text="{Binding City}"
                                   FontSize="18"/>
                            <Label Text=", "
                                   FontSize="18"/>
                            <Label Text="{Binding ZipCode}"
                                   FontSize="18"/>
                        </HorizontalStackLayout>
                        <Label x:Name="CountryLabel"
                               Text="{Binding Country}"
                               IsVisible="True"
                               HorizontalTextAlignment="Center"
                               FontSize="18"/>
                        <Label Text="Admin Priveledges?"
                               Style="{StaticResource SubHeadline}"
                               Margin="0,20,0,5"/>
                        <Switch x:Name="IsAdminSwitch"
                                HorizontalOptions="Center"
                                IsToggled="{Binding IsAdmin}"
                                IsVisible="True"
                                IsEnabled="True"/>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*"
                          Grid.Row="2">
                        
                        <Button Grid.Column="0"
                                Text="Close"
                                Style="{StaticResource OverlayButton}"
                                HorizontalOptions="Center"
                                WidthRequest="75"
                                Clicked="OnSelectedUserCancelButtonClicked"/>

                        <Button Grid.Column="1"
                                Text="Save"
                                Style="{StaticResource OverlayButton}"
                                HorizontalOptions="Center"
                                WidthRequest="75"
                                Clicked="OnSelectedUserSaveButtonClicked" />
                    </Grid>
                    
                    

                </Grid>

            </Border>
        </Border>
    </Grid>

</ContentView>
